            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
        <always_on>1</always_on>
        <visualize>true</visualize>
      </sensor>
    </link>
    <joint name='tof_rear_left_joint' type='fixed'>
      <parent>base_footprint</parent>
      <child>tof_rear_left_sensor</child>
    </joint>

    <!-- Rear-right corner TOF sensor (angled 15° outward) -->
    <link name='tof_rear_right_sensor'>
      <pose relative_to='base_footprint'>-0.15 -0.08 0.08 0 0 3.40339</pose>
      <sensor name='tof_rear_right' type='gpu_lidar'>
        <topic>/jetacker/tof_rear_right</topic>
        <gz_frame_id>tof_rear_right_link</gz_frame_id>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>5</samples>
              <resolution>1</resolution>
              <min_angle>-0.1745</min_angle>
              <max_angle>0.1745</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.05</min>
            <max>0.7</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </lidar>
        <always_on>1</always_on>
        <visualize>true</visualize>
      </sensor>
    </link>
    <joint name='tof_rear_right_joint' type='fixed'>
      <parent>base_footprint</parent>
      <child>tof_rear_right_sensor</child>
    </joint>

    <!-- Joint POSITION controller plugin for GUI control -->
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>turret_joint</joint_name>
      <p_gain>1</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.01</d_gain>
    </plugin>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>front_steering_joint</joint_name>
      <p_gain>1</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.01</d_gain>
    </plugin>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>front_left_wheel_steering_joint</joint_name>
      <p_gain>1</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.01</d_gain>
    </plugin>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>front_right_wheel_steering_joint</joint_name>
      <p_gain>1</p_gain>
      <i_gain>0.1</i_gain>
      <d_gain>0.01</d_gain>
    </plugin>
    <plugin
      filename="gz-sim-joint-controller-system"
      name="gz::sim::systems::JointController">
      <joint_name>rear_left_wheel_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
    </plugin>
    <plugin
      filename="gz-sim-joint-controller-system"
      name="gz::sim::systems::JointController">
      <joint_name>rear_right_wheel_joint</joint_name>
      <initial_velocity>0.0</initial_velocity>
    </plugin>

  </model>
</sdf>
