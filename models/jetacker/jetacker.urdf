      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>
  <joint name="tof_rear_left_joint" type="fixed">
    <origin rpy="0 0 2.8797932657906435" xyz="-0.15 0.08 0.08"/>
    <parent link="base_link"/>
    <child link="tof_rear_left_link"/>
  </joint>
  <link name="tof_rear_right_link">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="red"/>
