    <collision>
      <origin rpy="1.5707963267948966 0 0" xyz="0 0.019 0"/>
      <geometry>
        <cylinder length="0.039" radius="0.05"/>
      </geometry>
    </collision>
  </link>
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin rpy="0 0 0" xyz="-0.106 0.091 0.0503"/>
    <axis xyz="0 1 0"/>
  </joint>
  <link name="rear_right_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="7.517500000000001e-05" ixy="0" ixz="0" iyy="7.517500000000001e-05" iyz="0" izz="0.00012500000000000003"/>
    </inertial>
    <visual>
      <origin rpy="-1.5707963267948966 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://jetacker_description/meshes/wheel_right_back.stl"/>
