  </link>
  <joint name="tof_rear_right_joint" type="fixed">
    <origin rpy="0 0 3.4033920413889427" xyz="-0.15 -0.08 0.08"/>
    <parent link="base_link"/>
    <child link="tof_rear_right_link"/>
  </joint>
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <origin rpy="0 0 -1.5707963267948966" xyz="0 0 0.1116"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>
  <link name="front_steering_link">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-05" ixy="0.0" ixz="0.0" iyy="1e-05" iyz="0.0" izz="1e-05"/>
    </inertial>
  </link>
  <joint name="front_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_steering_link"/>
    <origin rpy="0 0 0" xyz="0.107 0 0.05"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" lower="-0.4887" upper="0.4887" velocity="1"/>
  </joint>
  <link name="front_left_wheel_steering">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="front_left_wheel_steering_joint" type="revolute">
    <parent link="base_link"/>
    <child link="front_left_wheel_steering"/>
    <origin rpy="0 0 0" xyz="0.107 0.091 0.05"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" lower="-0.4887" upper="0.4887" velocity="1"/>
    <mimic joint="front_steering_joint" multiplier="1.0" offset="0.0"/>
  </joint>
  <link name="front_left_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="7.517500000000001e-05" ixy="0" ixz="0" iyy="7.517500000000001e-05" iyz="0" izz="0.00012500000000000003"/>
    </inertial>
    <visual>
      <origin rpy="-1.5707963267948966 0 0" xyz="0 0 0"/>
      <geometry>
