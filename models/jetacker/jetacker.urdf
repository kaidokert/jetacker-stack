    <child link="front_right_wheel_steering"/>
    <origin rpy="0 0 0" xyz="0.107 -0.091 0.05"/>
    <axis xyz="0 0 1"/>
    <limit effort="10" lower="-0.4887" upper="0.4887" velocity="1"/>
    <mimic joint="front_steering_joint" multiplier="1.0" offset="0.0"/>
  </joint>
  <link name="front_right_wheel">
    <inertial>
