<?xml version="1.0"?>
<robot name="slam_bot">

  <!-- Base Link (scaled to 1/6 size for ~real robot dimensions) -->
  <link name="base_link">
    <visual>
      <origin xyz="-0.025238 0 0.029167" rpy="0 0 0"/>
      <geometry>
        <box size="0.335237 0.166667 0.094788"/>
      </geometry>
      <material name="blue">
        <color rgba="0.5 0.5 1.0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.025238 0 0.029167" rpy="0 0 0"/>
      <geometry>
        <box size="0.335237 0.166667 0.094788"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="-0.025238 0 0.029167" rpy="0 0 0"/>
      <mass value="3.0"/>
      <inertia ixx="0.027" ixy="0.0" ixz="0.0"
               iyy="0.089" iyz="0.0"
               izz="0.103"/>
    </inertial>
  </link>

  <!-- Left Wheel (scaled) -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.0004" ixy="0.0" ixz="0.0"
               iyy="0.0004" iyz="0.0"
               izz="0.0004"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.092380 0.104171 -0.004167" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Right Wheel (scaled) -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.0004" ixy="0.0" ixz="0.0"
               iyy="0.0004" iyz="0.0"
               izz="0.0004"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.092380 -0.104171 -0.004167" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Caster Wheel (scaled) -->
  <link name="caster">
    <visual>
      <geometry>
        <sphere radius="0.033333"/>
      </geometry>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.033333"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.00017" ixy="0.0" ixz="0.0"
               iyy="0.00017" iyz="0.0"
               izz="0.00017"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="-0.159523 0 -0.020833" rpy="0 0 0"/>
  </joint>

  <!-- Lidar Sensor Link (scaled) -->
  <link name="lidar_link">
    <visual>
      <geometry>
        <cylinder radius="0.008333" length="0.008333"/>
      </geometry>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.000463"/>
      <inertia ixx="0.0000000129" ixy="0.0" ixz="0.0"
               iyy="0.0000000129" iyz="0.0"
               izz="0.0000000129"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.133333 0 0.066667" rpy="0 0 0"/>
  </joint>

  <!-- IMU Sensor Link (scaled) -->
  <link name="imu_link">
    <inertial>
      <mass value="0.000046"/>
      <inertia ixx="0.00000000129" ixy="0.0" ixz="0.0"
               iyy="0.00000000129" iyz="0.0"
               izz="0.00000000129"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ros2_control Hardware Interface -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="left_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="right_wheel_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>
